{
  "name": "grand-river-commons",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-first MVP for a permaculture hex-card strategy game.",
  "scripts": {
    "dev": "node scripts/serve.mjs",
    "start": "node scripts/serve.mjs",
    "test": "node --test tests/*.test.js",
    "smoke": "node scripts/smoke.mjs",
    "verify": "npm test && npm run smoke",
    "docker:build": "docker build -t grand-river-commons .",
    "docker:run": "docker run --rm -p 5173:5173 grand-river-commons"
  },
  "keywords": ["permaculture", "hex-grid", "deck-building", "strategy", "simulation"],
  "license": "MIT"
}
